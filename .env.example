# Optional override for document-agent-api base URL.
# If omitted, the web app uses http://localhost:8000.
NEXT_PUBLIC_DOCUMENT_AGENT_API_BASE_URL=http://127.0.0.1:8000

# Optional login credentials for the dashboard.
# In development, if these are omitted, demo / demo1234 is used.
DOCMATE_AUTH_USERNAME=demo
DOCMATE_AUTH_PASSWORD=demo1234
DOCMATE_AUTH_DISPLAY_NAME=Demo Admin
DOCMATE_AUTH_SECRET=change-me-in-production
